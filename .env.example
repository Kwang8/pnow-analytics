POKERNOW_IMPORT_UID=your_firebase_auth_uid
POKERNOW_IMPORT_EMAIL=you@example.com
POKERNOW_IMPORT_KEY=replace_with_a_secret_key

# Option A: paste the whole service account JSON on one line
FIREBASE_SERVICE_ACCOUNT_JSON={"projectId":"...","clientEmail":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Option B: provide the fields separately instead
# FIREBASE_ADMIN_PROJECT_ID=...
# FIREBASE_ADMIN_CLIENT_EMAIL=...
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
